# Dioxus SPA build output. `crates/web/assets/tailwind.css` is generated by
# dx's auto-Tailwind step; `crates/web/dist/` is populated by
# `just build-dioxus` (copy of `target/dx/.../web/public/`). Neither belongs in git.
/crates/web/dist/*
!/crates/web/dist/.gitkeep
/crates/web/assets/tailwind.css
