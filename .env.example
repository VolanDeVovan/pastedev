# paste-server environment. Copy to .env and adjust.

# --- required ---
# Generate with: openssl rand -base64 48
PASTE_SECRET=change-me

DATABASE_URL=postgres://paste:paste@localhost:5432/paste

# --- networking ---
BIND_ADDR=0.0.0.0:8080
PUBLIC_BASE_URL=http://localhost:8080
# Empty = same-origin (SPA uses relative URLs). For split-origin deploys, set to absolute API host.
API_BASE_URL=

APP_NAME=paste

# --- sessions ---
# lax for same-origin (default); none for split-origin (requires SESSION_COOKIE_SECURE=true).
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false
SESSION_TTL_SECONDS=2592000

# Comma-separated absolute origins. Empty = no cross-origin allowed.
CORS_ALLOWED_ORIGINS=

# --- limits ---
SNIPPET_MAX_BYTES=1048576

# --- argon2 tuning (target ~150ms on prod host) ---
ARGON2_M_KIB=65536
ARGON2_T_COST=3

# --- runtime ---
RATE_LIMIT_PROFILE=default
RUST_LOG=paste_server=info,tower_http=info,sqlx=warn
RUST_ENV=production
